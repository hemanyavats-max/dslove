<script>

// ── FLOATING HEARTS ──
const HEARTS = ['❤️','🩷','💕','💖','💝','✨','💗'];
const layer  = document.getElementById('heartsLayer');
function spawnHeart(){
  const h=document.createElement('div'); h.className='fheart';
  h.textContent = HEARTS[Math.floor(Math.random()*HEARTS.length)];
  h.style.left  = Math.random()*100+'vw';
  const dur = 11+Math.random()*13, del = Math.random()*5;
  h.style.animationDuration = dur+'s';
  h.style.animationDelay   = del+'s';
  h.style.fontSize = (9+Math.random()*13)+'px';
  layer.appendChild(h);
  setTimeout(()=>h.remove(),(dur+del)*1000);
}
for(let i=0;i<20;i++) spawnHeart();
setInterval(spawnHeart, 850);

const phaseOpen = {};
function togglePhase(id){
  phaseOpen[id] = !phaseOpen[id];
  const body  = document.getElementById('pb-'+id);
  const btn   = document.getElementById('phbtn-'+id);
  const chev  = document.getElementById('phchev-'+id);
  body.classList.toggle('open', phaseOpen[id]);
  btn.classList.toggle('open', phaseOpen[id]);
  chev.classList.toggle('open', phaseOpen[id]);
  chev.textContent = phaseOpen[id] ? '▲' : '▼';
}

// ── NODE TOGGLE ──
function toggleNode(id){
  const body = document.getElementById('nb-'+id);
  const tog  = document.getElementById('nt-'+id);
  const hdr  = tog.closest('.node-hdr');
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open',!isOpen);
  tog.classList.toggle('open',!isOpen);
  tog.textContent = isOpen ? '▼':'▲';
  if(hdr) hdr.classList.toggle('open',!isOpen);
  calcProgress();
}

const done = {};
const ALL_NODES = ['n-python','n-math','n-da','n-sql','n-dl','n-nlp','n-cap'];
function markDone(e,id){
  e.stopPropagation();
  done[id] = !done[id];
  document.getElementById('dc-'+id).classList.toggle('done', done[id]);
  if(done[id]) burst(e.clientX, e.clientY);
  calcProgress();
}
function burst(x,y){
  const cols=['#ff2d6b','#ff6eb4','#f5c97a','#c084fc','#ffffff'];
  for(let i=0;i<10;i++){
    const p=document.createElement('div');
    p.style.cssText=`position:fixed;left:${x}px;top:${y}px;width:5px;height:5px;border-radius:50%;background:${cols[i%cols.length]};pointer-events:none;z-index:9999;`;
    document.body.appendChild(p);
    const ang=(i/10)*Math.PI*2, dist=35+Math.random()*30;
    p.animate([
      {transform:`translate(-50%,-50%) scale(1)`,opacity:1},
      {transform:`translate(calc(-50% + ${Math.cos(ang)*dist}px),calc(-50% + ${Math.sin(ang)*dist}px)) scale(0)`,opacity:0}
    ],{duration:580,easing:'cubic-bezier(0,0,0.2,1)',fill:'forwards'});
    setTimeout(()=>p.remove(),640);
  }
}

function calcProgress(){
  const n = ALL_NODES.filter(id=>done[id]).length;
  const pct = Math.round(n/ALL_NODES.length*100);
  document.getElementById('pFill').style.width = pct+'%';
  document.getElementById('pTxt').textContent =
    n===0 ? 'ready to begin, baby ✦' :
    n===ALL_NODES.length ? 'you did it!! I love you so much ❤️' :
    `${n} of ${ALL_NODES.length} complete - keep going! 🌸`;
}

// ── EXPAND ALL ──
const PHASES=['ph1','ph2','ph3','ph4','ph5'];
let allOpen=false;
function toggleAll(){
  allOpen=!allOpen;
  PHASES.forEach(id=>{
    phaseOpen[id]=allOpen;
    document.getElementById('pb-'+id).classList.toggle('open',allOpen);
    const btn=document.getElementById('phbtn-'+id);
    const chev=document.getElementById('phchev-'+id);
    btn.classList.toggle('open',allOpen);
    chev.classList.toggle('open',allOpen);
    chev.textContent=allOpen?'▲':'▼';
  });
  document.getElementById('expandLbl').textContent = allOpen?'collapse all phases':'expand all phases';
}
</script>
